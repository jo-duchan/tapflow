# dependencies
node_modules/

# build outputs
dist/
out/
.next/
*.tgz

# dashboard build bundled into relay
packages/relay/public/

# local work logs (not for contributors)
.work/

# env
.env
.env.local
.env.*.local

# tapflow runtime config (auto-generated, may contain local paths)
tapflow.config.json

# os
.DS_Store

# playwright mcp artifacts
.playwright-mcp/
*.png
!docs/public/*.png

# vscode
.vscode

# typescript build cache
*.tsbuildinfo

# cli pack artifacts
*.tgz

# claude code personal settings (team settings and commands are tracked)
.claude/settings.local.json

# sqlite wal/shm temp files
*.db-shm
*.db-wal

# runtime data (recordings, uploads, db, generated jwt-secret) — any package/cwd.
# **/ prefix so it matches in subpackages too (a mid-pattern slash would anchor to repo root).
# .tapflow/flows/ stays tracked — only the runtime subdirs are ignored.
**/.tapflow/data/
**/.tapflow/artifacts/
.tapflow-data/

# playground test builds
playground/test-builds/

# playground demo/local scripts (not for contributors)
playground/demo-seed.ts
playground/multi-agent.ts

# VitePress
docs/.vitepress/cache
docs/.vitepress/dist
.internal/

# curl test artifacts
cookies.txt

# skills install artifacts (a11y-lens etc.)
.agents/
skills-lock.json
