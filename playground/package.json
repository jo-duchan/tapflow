{
  "name": "@tapflowio/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo 'No tests for playground'",
    "relay": "tsx --conditions=source relay.ts",
    "ios-agent": "tsx --conditions=source ios-agent.ts",
    "android-agent": "tsx --conditions=source android-agent.ts",
    "mock-agents": "tsx --conditions=source multi-agent.ts",
    "seed": "tsx --conditions=source seed.ts",
    "demo-seed": "tsx --conditions=source demo-seed.ts",
    "doctor": "tsx --conditions=source ../packages/cli/src/index.ts doctor",
    "reset": "tsx --conditions=source ../packages/cli/src/index.ts reset",
    "mcp": "tsx --conditions=source ../packages/mcp-server/src/index.ts",
    "pre-release": "pnpm --filter @tapflowio/relay build && pnpm --filter @tapflowio/dashboard build && pnpm tsx ../packages/cli/src/index.ts relay start"
  },
  "dependencies": {
    "@tapflowio/agent-core": "workspace:*",
    "@tapflowio/ios-agent": "workspace:*",
    "@tapflowio/android-agent": "workspace:*",
    "@tapflowio/relay": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "tsx": "^4.23.0",
    "typescript": "^5.0.0"
  }
}
