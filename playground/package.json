{
  "name": "@tapflow/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo 'No tests for playground'",
    "relay": "tsx --conditions=source relay.ts",
    "seed": "tsx --conditions=source seed.ts",
    "ios-agent": "tsx --conditions=source ios-agent.ts",
    "android-agent": "tsx --conditions=source android-agent.ts",
    "dev:doctor": "tsx --conditions=source ../packages/cli/src/index.ts doctor",
    "dev:reset": "tsx --conditions=source ../packages/cli/src/index.ts reset",
    "dev:up": "concurrently -n relay,agent -c cyan,green \"npm run relay\" \"npm run ios-agent\"",
    "dev:up:full": "concurrently -k -n relay,ios,android -c cyan,green,yellow \"npm run relay\" \"npm run ios-agent\" \"npm run android-agent\""
  },
  "dependencies": {
    "@tapflow/agent-core": "*",
    "@tapflow/ios-agent": "*",
    "@tapflow/android-agent": "*",
    "@tapflow/relay": "*",
    "@tapflow/cli": "*"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
