{
  "name": "@tapflow/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "echo 'No tests for playground'",
    "relay": "tsx --conditions=source relay.ts",
    "seed": "tsx --conditions=source seed.ts",
    "ios-agent": "tsx --conditions=source ios-agent.ts",
    "android-agent": "tsx --conditions=source android-agent.ts",
    "dev:doctor": "tsx --conditions=source ../packages/cli/src/index.ts doctor",
    "dev:reset": "tsx --conditions=source ../packages/cli/src/index.ts reset",
    "mock-agent": "tsx --conditions=source mock-agent.ts",
    "mock-agents": "tsx --conditions=source multi-agent.ts",
    "dev:up": "concurrently -n relay,agent -c cyan,green \"pnpm relay\" \"pnpm ios-agent\"",
    "dev:up:full": "concurrently -k -n relay,ios,android -c cyan,green,yellow \"pnpm relay\" \"pnpm ios-agent\" \"pnpm android-agent\"",
    "dev:up:pool": "concurrently -k -n relay,ios,mocks -c cyan,green,yellow \"pnpm relay\" \"pnpm ios-agent\" \"pnpm mock-agents\""
  },
  "dependencies": {
    "@tapflow/agent-core": "workspace:*",
    "@tapflow/ios-agent": "workspace:*",
    "@tapflow/android-agent": "workspace:*",
    "@tapflow/relay": "workspace:*",
    "@tapflow/cli": "workspace:*"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
