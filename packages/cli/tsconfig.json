{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "composite": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/__tests__",
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../agent-core"
    },
    {
      "path": "../ios-agent"
    },
    {
      "path": "../android-agent"
    },
    {
      "path": "../relay"
    }
  ]
}
