{
  "name": "@tapflowio/flow-runner",
  "version": "0.14.0",
  "description": "Deterministic YAML flow runner for tapflow — replay UI test flows against simulators/emulators with zero LLM calls",
  "keywords": [
    "tapflow",
    "flow",
    "ui-testing",
    "ios",
    "android",
    "simulator",
    "ci"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/flow-runner"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema/tapflow-flow.schema.json": "./schema/tapflow-flow.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@tapflowio/agent-core": "workspace:*",
    "ws": "^8.21.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
