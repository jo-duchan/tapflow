{
  "name": "@tapflowio/relay",
  "version": "0.2.2",
  "description": "WebSocket relay server for tapflow — NAT traversal, session routing, JWT auth, bundled dashboard",
  "keywords": [
    "tapflow",
    "relay",
    "websocket",
    "self-hosted",
    "ios",
    "android",
    "simulator"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/relay"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/migrations && cp -r src/migrations dist/migrations",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@tapflowio/agent-core": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "busboy": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "ws": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
