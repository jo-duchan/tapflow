{
  "name": "@tapflow/relay",
  "private": true,
  "version": "0.1.0",
  "description": "WebSocket relay server with bundled dashboard — NAT traversal, session routing, JWT auth",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "files": [
    "dist",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r src/migrations dist/migrations",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "busboy": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
