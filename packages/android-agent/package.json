{
  "name": "@tapflowio/android-agent",
  "version": "0.13.0",
  "description": "Android emulator agent for tapflow — ADB control and scrcpy H.264 streaming",
  "keywords": [
    "tapflow",
    "android",
    "emulator",
    "adb",
    "scrcpy",
    "streaming",
    "qa"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/android-agent"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src",
    "download-scrcpy-server": "node scripts/download-scrcpy-server.mjs"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@tapflowio/agent-core": "workspace:*",
    "@tapflowio/audiotap-helper": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tapflowio/relay": "workspace:*",
    "@types/node": "^20.19.43",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
