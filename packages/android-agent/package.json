{
  "name": "@tapflowio/android-agent",
  "version": "0.1.0-alpha.1",
  "description": "Android emulator agent for tapflow — ADB control and scrcpy H.264 streaming",
  "keywords": ["tapflow", "android", "emulator", "adb", "scrcpy", "streaming", "qa"],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/android-agent"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "download-scrcpy-server": "node scripts/download-scrcpy-server.mjs"
  },
  "dependencies": {
    "@tapflowio/agent-core": "workspace:*",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@tapflowio/relay": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
