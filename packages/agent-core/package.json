{
  "name": "@tapflowio/agent-core",
  "version": "0.1.0-alpha.5",
  "description": "DeviceAgent interface, AgentRegistry, and shared utilities for tapflow agents",
  "keywords": [
    "tapflow",
    "ios",
    "android",
    "simulator",
    "emulator",
    "device-agent"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/agent-core"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "source": "./src/utils/index.ts",
      "tsx": "./src/utils/index.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
