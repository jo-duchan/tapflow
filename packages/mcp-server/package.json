{
  "name": "@tapflowio/mcp-server",
  "version": "0.5.1-experimental.1",
  "description": "MCP server for tapflow — lets LLM agents control iOS/Android simulators via Model Context Protocol",
  "keywords": [
    "tapflow",
    "mcp",
    "model-context-protocol",
    "ios",
    "android",
    "simulator",
    "ai-agent"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/mcp-server"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tapflow-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "tag": "experimental",
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
