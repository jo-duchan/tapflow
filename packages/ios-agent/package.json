{
  "name": "@tapflowio/ios-agent",
  "version": "0.8.0-next.0",
  "description": "iOS simulator agent for tapflow — xcrun simctl control and screen streaming",
  "keywords": [
    "tapflow",
    "ios",
    "simulator",
    "xcrun",
    "simctl",
    "streaming",
    "qa"
  ],
  "homepage": "https://github.com/jo-duchan/tapflow",
  "bugs": "https://github.com/jo-duchan/tapflow/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/jo-duchan/tapflow.git",
    "directory": "packages/ios-agent"
  },
  "license": "MIT",
  "author": "tapflow contributors",
  "os": [
    "darwin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "tsx": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node -e \"if (process.platform === 'darwin') { require('fs').readdirSync('bin').forEach(f => require('fs').chmodSync('bin/' + f, 0o755)) }\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@tapflowio/agent-core": "workspace:*",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@tapflowio/relay": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
